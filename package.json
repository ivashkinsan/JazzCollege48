{
  "name": "lipetsk-college-arts",
  "private": true,
  "version": "0.0.5",
  "type": "module",
  "scripts": {
    "dev": "tsx src/server/utils/generate-static-data.ts && vite",
    "build": "tsc --build tsconfig.node.json && tsx src/server/utils/generate-static-data.ts && tsc && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "deploy": "npm run build && node scripts/deploy.js",
    "build:server": "tsc --project tsconfig.node.json",
    "admin": "npm run build:server && node dist/server/main.js",
    "db:setup": "tsx scripts/db-setup.ts",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "db:cleanup": "tsx scripts/db-cleanup.ts",
    "db:add-subcategory": "tsx scripts/db-add-subcategory.ts",
    "db:create-achievements": "tsx scripts/db-create-achievements-table.ts",
    "db:migrate-achievements": "tsx scripts/db-migrate-achievements.ts",
    "db:create-videos": "tsx scripts/db-create-videos-table.ts",
    "db:migrate-videos": "tsx scripts/db-migrate-videos.ts",
    "db:create-library": "tsx scripts/db-create-library-table.ts",
    "db:migrate-library": "tsx scripts/db-migrate-library.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.22",
    "@nestjs/core": "^10.4.22",
    "@nestjs/platform-express": "^10.4.22",
    "@types/cors": "^2.8.19",
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet-async": "^3.0.0",
    "react-markdown": "^10.1.0",
    "react-mobile-picker": "^1.2.0",
    "react-router-dom": "^7.13.2",
    "reflect-metadata": "^0.2.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@nestjs/cli": "^11.0.24",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "basic-ftp": "^6.0.1",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "express": "^5.2.1",
    "globals": "^17.4.0",
    "multer": "^2.2.0",
    "open": "^11.0.0",
    "sharp": "^0.35.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.23.0",
    "typescript": "^6.0.2",
    "unplugin-imagemin": "^0.7.0",
    "vite": "^8.0.1",
    "vite-plugin-image-optimizer": "^2.0.3",
    "vite-plugin-pwa": "^1.3.0"
  }
}
