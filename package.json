{
  "name": "lipetsk-college-arts",
  "private": true,
  "version": "0.0.4",
  "type": "module",
  "scripts": {
    "dev": "ts-node scripts/generate-static-data.ts && vite",
    "build": "ts-node scripts/generate-static-data.ts && tsc && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "deploy": "npm run build && node scripts/deploy.js",
    "admin": "ts-node scripts/generate-static-data.ts && ts-node scripts/admin-server.ts",
    "db:setup": "ts-node scripts/db-setup.ts",
    "db:migrate": "ts-node scripts/db-migrate.ts",
    "db:cleanup": "ts-node scripts/db-cleanup.ts",
    "db:add-subcategory": "ts-node scripts/db-add-subcategory.ts",
    "db:create-achievements": "ts-node scripts/db-create-achievements-table.ts",
    "db:migrate-achievements": "ts-node scripts/db-migrate-achievements.ts",
    "db:create-videos": "ts-node scripts/db-create-videos-table.ts",
    "db:migrate-videos": "ts-node scripts/db-migrate-videos.ts",
    "db:create-library": "ts-node scripts/db-create-library-table.ts",
    "db:migrate-library": "ts-node scripts/db-migrate-library.ts"
  },
  "dependencies": {
    "@types/cors": "^2.8.19",
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.13.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "basic-ftp": "^6.0.1",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "express": "^5.2.1",
    "globals": "^17.4.0",
    "multer": "^2.2.0",
    "open": "^11.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "unplugin-imagemin": "^0.7.0",
    "vite": "^8.0.1"
